# Shodan API Configuration
SHODANAPI=

# Cloudflare API Configuration (Optional - for high-fidelity screenshots and URL scanning)
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Global Scanner Configuration
SCREENSHOT_ENABLED=true
MAX_SCREENSHOTS=50
SCREENSHOT_TIMEOUT_SECONDS=90
SCREENSHOT_WIDTH=1440
SCREENSHOT_HEIGHT=1024
NUCLEI_ENABLED=true
NUCLEI_TARGET_LIMIT=250
NUCLEI_NETWORK_TARGET_LIMIT=150
NUCLEI_TAGS=misconfig,exposure,takeover,cve,tech,default-login,ssl,tls,dns,network
NUCLEI_SEVERITIES=critical,high,medium,low
# Optional deeper discovery tools are controlled in config/config.yaml:
# chaos-client, Shodan hostname search, and nmap are enabled by default.

# Optional Codex operator context
# The deterministic scanner does not invoke Codex as a subprocess.
C3PO_CODEX_MODEL=
C3PO_CODEX_REASONING_EFFORT=
# Fast mode is independent of the model catalog. Leave empty unless selected.
C3PO_CODEX_FAST_MODE=
# Set to never or pass --no-model-prompt to suppress the interactive menu.
C3PO_MODEL_PROMPT=auto

# External Context Refresh (Optional)
OPENCLAW_ALLOW_REMOTE_CONTEXT_UPDATE=0
OPENCLAW_CONTEXT_URL=
OPENCLAW_CONTEXT_SHA256=
